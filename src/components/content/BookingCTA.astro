---
import Button from './Button.astro';
import { site } from '../../data/site';
const { title = 'Conversemos sobre la plataforma que tu institución necesita.', body = 'Agenda una conversación inicial o envíanos los antecedentes de tu proyecto mediante nuestro brief.' } = Astro.props;
---

<section class="bg-brand-navy py-section-sm text-white">
  <div class="mx-auto flex max-w-content flex-col gap-6 px-5 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
    <div>
      <h2 class="text-3xl font-black">{title}</h2>
      <p class="mt-3 max-w-2xl text-white/75">{body}</p>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row">
      <Button target="_blank" href={site.bookingUrl} variant="light">Agendar una reunión</Button>
      <Button href="/contacto/#project-brief">Cuéntanos tu proyecto</Button>
    </div>
  </div>
</section>
