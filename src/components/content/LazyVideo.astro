---
const { provider = 'youtube', id, title } = Astro.props;
const src = provider === 'youtube' ? `https://www.youtube-nocookie.com/embed/${id}` : `https://iframe.videodelivery.net/${id}`;
---

<details class="rounded-card border border-border bg-surface p-4">
  <summary class="cursor-pointer font-black text-brand-navy">Reproducir video: {title}</summary>
  <iframe class="mt-4 aspect-video w-full rounded-control border-0" src={src} title={title} loading="lazy" allow="accelerometer; autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>
</details>
