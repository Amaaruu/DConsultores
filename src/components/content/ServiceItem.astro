---
const { service } = Astro.props;
---

<article class="border-t border-border py-8">
  <div class="grid gap-5 md:grid-cols-[0.8fr_1.2fr]">
    <div>
      <h2 class="text-2xl font-black text-brand-navy">{service.title}</h2>
      <p class="mt-3 text-sm font-bold text-brand-orange">{service.problem}</p>
    </div>
    <div>
      <p class="leading-7 text-muted">{service.body}</p>
      <p class="mt-4 font-bold text-ink">Resultado: {service.result}</p>
      <ul class="mt-5 flex flex-wrap gap-2">
        {service.capabilities.map((item: string) => (
          <li class="rounded-full border border-border bg-surface px-3 py-1 text-sm text-muted">{item}</li>
        ))}
      </ul>
    </div>
  </div>
</article>
