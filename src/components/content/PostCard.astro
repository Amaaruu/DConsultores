---
import PostMeta from './PostMeta.astro';
const { post } = Astro.props;
---

<article class="rounded-card border border-border bg-surface p-6">
  <PostMeta post={post} />
  <h2 class="mt-3 text-2xl font-black text-brand-navy">
    <a href={`/publicaciones/${post.id}/`} class="hover:text-brand-orange">{post.data.title}</a>
  </h2>
  <p class="mt-3 leading-7 text-muted">{post.data.description}</p>
  <ul class="mt-5 flex flex-wrap gap-2">
    {post.data.tags.map((tag: string) => <li class="rounded-full bg-brand-orange-soft px-3 py-1 text-xs font-bold text-brand-navy">{tag}</li>)}
  </ul>
</article>
