---
const { service } = Astro.props;
---

<article class="rounded-card border border-border bg-surface p-6">
  <p class="text-sm font-black uppercase tracking-wide text-brand-orange">{service.data.icon}</p>
  <h2 class="mt-3 text-2xl font-black text-brand-navy">
    <a href={`/servicios/${service.id}/`} class="hover:text-brand-orange">{service.data.shortTitle}</a>
  </h2>
  <p class="mt-3 leading-7 text-muted">{service.data.description}</p>
  <ul class="mt-5 flex flex-wrap gap-2">
    {service.data.capabilities.slice(0, 4).map((item: string) => <li class="rounded-full bg-page px-3 py-1 text-xs font-bold text-brand-navy">{item}</li>)}
  </ul>
</article>
