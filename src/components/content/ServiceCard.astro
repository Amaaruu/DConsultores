---
const { service } = Astro.props;
const iconType = service.data.icon;
---

<article class="group relative rounded-card border border-border bg-surface p-6 transition-all duration-300 ease-out hover:scale-[1.03] hover:shadow-lg hover:border-brand-orange/30">
  
  <div class="flex items-center justify-between">
    <div class="flex size-12 items-center justify-center rounded-control bg-brand-orange-soft text-brand-orange">
      {iconType === 'dspace' ? (
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      ) : iconType === 'dataverse' ? (
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.58 4 8 4s8-1.79 8-4M4 7c0-2.21 3.58-4 8-4s8 1.79 8 4m0 5c0 2.21-3.58 4-8 4s-8-1.79-8-4" />
        </svg>
      ) : iconType === 'support' ? (
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      ) : (
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
        </svg>
      )}
    </div>
  </div>

  <h2 class="mt-6 text-2xl font-black text-brand-navy">
    <a href={`/servicios/${service.id}/`} class="hover:text-brand-orange before:absolute before:inset-0">
      {service.data.shortTitle}
    </a>
  </h2>
  <p class="mt-3 leading-7 text-muted">{service.data.description}</p>
</article>