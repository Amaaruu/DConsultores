---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/content/Button.astro';
import BookingCTA from '../components/content/BookingCTA.astro';
import PostCard from '../components/content/PostCard.astro';
import ProjectCard from '../components/content/ProjectCard.astro';
import ServiceCard from '../components/content/ServiceCard.astro';
import { site } from '../data/site';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const services = (await getCollection('services')).filter((service) => !service.data.draft).sort((a, b) => a.data.order - b.data.order);
const featuredServices = services.filter((service) => service.data.featured).slice(0, 4);
const projectCandidates = (await getCollection('projects')).slice(0, 2);
---

<BaseLayout seo={{ title: 'Plataformas digitales para preservar, organizar y conectar conocimiento', description: site.description, path: '/' }}>
  <section class="bg-surface py-section-sm md:py-section-lg">
    <div class="mx-auto grid max-w-wide gap-12 px-5 sm:px-6 md:grid-cols-[1.05fr_0.95fr] md:items-center lg:px-8">
      <div>
        <p class="font-black uppercase tracking-wide text-brand-orange">Sistemas digitales de información y conocimiento</p>
        <h1 class="mt-4 text-4xl font-black tracking-normal text-brand-navy md:text-6xl">Plataformas digitales para preservar, organizar y conectar conocimiento.</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">Diseñamos, implementamos y mantenemos repositorios digitales, bibliotecas, plataformas de datos y soluciones de información para universidades, organismos públicos y organizaciones.</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <Button target="_blank" href={site.bookingUrl}>Agendar una reunión</Button>
          <Button href="/contacto/#project-brief" variant="secondary">Cuéntanos tu proyecto</Button>
          <a href="/servicios/" class="font-black text-brand-navy underline decoration-brand-orange decoration-2">Conocer servicios</a>
        </div>
      </div>
      <div class="rounded-card border border-border bg-page p-6">
        <div class="grid gap-4">
          {featuredServices.map((service, index) => (
            <div class="flex items-start gap-4 rounded-control bg-surface p-4">
              <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-brand-orange-soft font-black text-brand-orange">0{index + 1}</span>
              <div>
                <p class="font-black text-brand-navy">{service.data.shortTitle}</p>
                <p class="mt-1 text-sm leading-6 text-muted">{service.data.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-page py-8">
    <div class="mx-auto max-w-content px-5 text-center text-sm font-black uppercase tracking-wide text-brand-navy sm:px-6 lg:px-8">
      Repositorios digitales · Datos de investigación · Desarrollo e integraciones · Soporte y continuidad operativa
    </div>
  </section>

  <section class="bg-surface py-section-sm">
    <div class="mx-auto max-w-content px-5 sm:px-6 lg:px-8">
      <p class="font-black uppercase tracking-wide text-brand-orange">Servicios principales</p>
      <h2 class="mt-3 text-3xl font-black text-brand-navy md:text-4xl">Soluciones especializadas para información digital.</h2>
      <p class="mt-4 max-w-3xl leading-8 text-muted">Acompañamos todo el ciclo de una plataforma: levantamiento, arquitectura, implementación, personalización, migración, integración, capacitación, soporte y evolución.</p>
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {featuredServices.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <section class="bg-page py-section-sm">
    <div class="mx-auto max-w-content px-5 sm:px-6 lg:px-8">
      <p class="font-black uppercase tracking-wide text-brand-orange">Diferenciadores</p>
      <h2 class="mt-3 text-3xl font-black text-brand-navy md:text-4xl">Especialización para plataformas que deben mantenerse disponibles.</h2>
      <div class="mt-10 grid gap-4 md:grid-cols-4">
        {['Experiencia especializada', 'Trabajo de principio a fin', 'Tecnologías abiertas', 'Transferencia de capacidades'].map((item) => (
          <article class="border-t border-border pt-5">
            <h3 class="font-black text-brand-navy">{item}</h3>
            <p class="mt-3 text-sm leading-6 text-muted">Decisiones documentadas, estándares abiertos y operación sostenible para instituciones.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-surface py-section-sm">
    <div class="mx-auto max-w-content px-5 sm:px-6 lg:px-8">
      <p class="font-black uppercase tracking-wide text-brand-orange">Proyectos</p>
      <h2 class="mt-3 text-3xl font-black text-brand-navy md:text-4xl">Referencias heredadas en revisión editorial.</h2>
      <p class="mt-4 max-w-3xl leading-8 text-muted">Los casos recuperados desde WordPress se muestran como candidatos hasta confirmar autorización, alcance e imágenes.</p>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {projectCandidates.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="bg-page py-section-sm">
    <div class="mx-auto max-w-content px-5 sm:px-6 lg:px-8">
      <p class="font-black uppercase tracking-wide text-brand-orange">Forma de trabajo</p>
      <h2 class="mt-3 text-3xl font-black text-brand-navy md:text-4xl">Un proceso claro desde el diagnóstico hasta la continuidad.</h2>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {['Comprender', 'Diseñar', 'Implementar', 'Validar', 'Transferir', 'Mantener'].map((step) => (
          <article class="border-l-4 border-brand-orange bg-surface p-5">
            <h3 class="font-black text-brand-navy">{step}</h3>
            <p class="mt-2 text-sm leading-6 text-muted">Etapa de trabajo con objetivos, evidencia y próximos pasos claros.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-surface py-section-sm">
    <div class="mx-auto max-w-content px-5 sm:px-6 lg:px-8">
      <p class="font-black uppercase tracking-wide text-brand-orange">Publicaciones</p>
      <h2 class="mt-3 text-3xl font-black text-brand-navy md:text-4xl">Notas recientes sobre tecnología institucional.</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
  <BookingCTA />
</BaseLayout>
