---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/content/BookingCTA.astro';
import ServiceCard from '../../components/content/ServiceCard.astro';

const services = (await getCollection('services'))
  .filter((service) => !service.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout seo={{ title: 'Servicios de Ingeniería y Repositorios', description: 'Servicios especializados en arquitectura, DSpace, Dataverse, infraestructura e Inteligencia Artificial aplicada.', path: '/servicios/' }}>
  <section class="bg-surface py-section-sm md:py-section-lg">
    <div class="mx-auto max-w-content px-5 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <p class="font-black uppercase tracking-wide text-brand-orange">Catálogo de Servicios</p>
        <h1 class="mt-4 text-4xl font-black tracking-normal text-brand-navy md:text-5xl">
          Ingeniería y soporte para ecosistemas de conocimiento.
        </h1>
        <p class="mt-6 text-lg leading-8 text-muted">
          Abarcamos el ciclo de vida completo de su plataforma: levantamiento funcional, arquitectura de software, implementación, integraciones críticas y continuidad operativa.
        </p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>
  <BookingCTA />
</BaseLayout>