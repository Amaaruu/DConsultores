---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/content/Button.astro';
---

<BaseLayout seo={{ title: 'Pagina no encontrada', description: 'La pagina solicitada no existe.', path: '/404/', noindex: true }}>
  <section class="bg-surface py-section-lg text-center">
    <div class="mx-auto max-w-reading px-5 sm:px-6 lg:px-8">
      <p class="font-black text-brand-orange">404</p>
      <h1 class="mt-3 text-4xl font-black text-brand-navy">Página no encontrada</h1>
      <p class="mt-5 text-muted">La URL no existe o fue movida.</p>
      <div class="mt-8"><Button href="/">Volver al inicio</Button></div>
    </div>
  </section>
</BaseLayout>
